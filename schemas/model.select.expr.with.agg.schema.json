{
  "$id": "model.select.expr.with.agg.schema.json",
  "title": "Schema Model Select Expr With Agg",
  "description": "Validate selecting a new column using an expression and creating an agg",
  "anyOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["expr", "name", "type"],
      "properties": {
        "agg": { "$ref": "column.agg.schema.json" },
        "aggs": { "$ref": "column.aggs.schema.json" },
        "data_type": { "$ref": "column.data_type.schema.json" },
        "description": { "$ref": "column.description.schema.json" },
        "expr": { "$ref": "column.expr.schema.json" },
        "lightdash": { "$ref": "column.lightdash.schema.json" },
        "meta": { "$ref": "column.meta.schema.json" },
        "name": { "$ref": "column.name.schema.json" },
        "override_suffix_agg": { "type": "boolean" },
        "data_tests": { "$ref": "column.data_tests.schema.json" },
        "type": { "const": "fct" }
      }
    }
  ]
}
