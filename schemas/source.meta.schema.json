{
  "$id": "source.meta.schema.json",
  "title": "Schema Source Meta",
  "description": "Validates schema for source meta (either on the schema or table level). Custom free-form keys (e.g. owner, owner_slack, freshness_sla) are permitted alongside the typed keys defined below.",
  "allowTrailingCommas": true,
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "etl": { "$ref": "source.etl.schema.json" },
    "event_datetime": { "$ref": "source.event_datetime.schema.json" },
    "partition_date": { "$ref": "source.partition_date.schema.json" },
    "partitions": {
      "type": "array",
      "items": { "$ref": "source.partition.schema.json" }
    },
    "portal_partition_columns": {
      "$ref": "source.portal_partition_columns.schema.json"
    },
    "portal_source_count": { "$ref": "source.portal_source_count.schema.json" },
    "table_function": { "$ref": "source.table_function.schema.json" },
    "where": { "$ref": "source.where.schema.json" }
  }
}
